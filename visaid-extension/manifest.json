{
  "manifest_version": 3,
  "name": "VisAid AI",
  "version": "1.0",
  "description": "AI powered voice assistant to help visually impaired users fill web forms.",

  "permissions": [
    "scripting",
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "http://13.232.1.76:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}